OPENCODEX_ADMIN_USERNAME=admin
OPENCODEX_ADMIN_PASSWORD=change-me
# 数据库提供程序: sqlite(默认) 或 postgres
OPENCODEX_DB_PROVIDER=sqlite
# SQLite 连接串(默认)
OPENCODEX_DB_CONNECTION_STRING=Data Source=/app/logs/opencodex.db
# PostgreSQL 连接串示例(使用 PG 时取消注释并替换为实际值):
# OPENCODEX_DB_PROVIDER=postgres
# OPENCODEX_DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=opencodex;Username=ocx;Password=change-me
OPENCODEX_LOG_PATH=/app/logs/opencodex.log
OPENCODEX_LOG_LEVEL=INFO
OPENCODEX_LOG_VIEW_LEVEL=BASIC
OPENCODEX_DEFAULT_TIMEOUT=120
OPENCODEX_ADMIN_COOKIE_DAYS=30
OPENCODEX_SECRET_KEY=change-me-session-secret
OPENCODEX_DATA_PROTECTION_KEYS_PATH=/app/logs/opencodex.keys
TZ=Asia/Shanghai
